# CASA Control Plane Environment Configuration
# Copy this file to .env and customize values for your deployment

# ==========================================
# Environment & Logging
# ==========================================

# Deployment Environment
# Options: production, staging, development
ENVIRONMENT=production

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# Security & Authentication
# ==========================================

# API Key for Bearer token authentication
# IMPORTANT: Change this to a strong random value in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CASA_API_KEY=casa-default-key-change-me

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==========================================
# Policy & Ledger Configuration
# ==========================================

# Policy Configuration File Path
# Relative path to policy JSON file
POLICY_FILE=policy.json

# Audit Ledger Path
# Where to write immutable audit trail logs
LEDGER_PATH=CASA/ledger.log
